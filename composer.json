{
  "name": "resqnet/platform",
  "description": "resqnet — Disaster early warning and post-disaster donation management system",
  "type": "project",
  "require": {
    "php": ">=8.0"
  },
  "scripts": {
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8001 -t public"
    ],
    "db:seed": [
      "@php database/seed.php"
    ],
    "start": [
      "@serve"
    ]
  }
}