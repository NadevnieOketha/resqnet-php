{
  "name": "resqnet/dms",
  "description": "Resqnet 21 — Plain PHP+MySQL Module-Based MVC Boilerplate",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8000 -t public"
    ],
    "start": [
      "@serve"
    ]
  },
  "autoload": {
    "files": [
      "core/helpers.php"
    ]
  }
}